{
  "name": "tgb-form",
  "private": true,
  "description": "An easy to use form library, with powerful schema-based form definition capabilities.",
  "homepage": "https://github.com/VueEasyForm/tgb-form#readme",
  "bugs": {
    "url": "https://github.com/VueEasyForm/tgb-form/issues"
  },
  "license": "MIT",
  "author": "The @tgb-form Authors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VueEasyForm/tgb-form.git"
  },
  "scripts": {
    "build": "turbo run build",
    "build:packages": "pnpm -r --filter \"./packages/*\" run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "test:packages": "pnpm -r --filter \"./packages/*\" run test",
    "lint": "oxlint --fix",
    "fmt": "oxfmt",
    "check-types": "turbo run typecheck",
    "check-types:packages": "pnpm -r --filter \"./packages/*\" run typecheck",
    "prepare": "husky",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build:packages && changeset publish",
    "release:check": "pnpm build:packages && pnpm test:packages && pnpm check-types:packages"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.1",
    "@faker-js/faker": "^10.5.0",
    "eslint-plugin-astro": "^3.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "turbo": "^2.10.5"
  },
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@11.11.0+sha512.4463f65fd80ed80d69bc1d4bf163ee94f605c7380fc318bb5b2ebe15f8cd12d49c51a4d59e951b401e764d3b6ca751cbf51bc50ed7001a6bcb4935e684c34882"
}
