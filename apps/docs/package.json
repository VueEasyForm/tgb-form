{
  "name": "@easyform/docs",
  "private": true,
  "description": "Documentations for @easyform/* packages, an easy to use form library, with powerful schema-based form definition capabilities.",
  "type": "module",
  "sideEffects": false,
  "scripts": {
    "content:gen": "fumadocs-mdx",
    "dev": "pnpm run content:gen && vite dev",
    "build": "pnpm run content:gen && vite build",
    "start": "serve .output/public --config ../../serve.json",
    "preview": "vite preview",
    "typecheck": "pnpm run types:check",
    "types:check": "pnpm run content:gen && tsc --noEmit"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/lora": "^5.2.8",
    "@fuma-translate/react": "^1.0.2",
    "@fumadocs/base-ui": "^16.11.1",
    "@icons-pack/react-simple-icons": "^13.13.0",
    "@orama/orama": "^3.1.18",
    "@tanstack/react-form": "^1.33.0",
    "@tanstack/react-router": "1.170.17",
    "@tanstack/react-router-devtools": "1.167.0",
    "@tanstack/react-start": "1.168.27",
    "@tanstack/start-static-server-functions": "1.167.18",
    "class-variance-authority": "^0.7.1",
    "cnfast": "^0.0.8",
    "fumadocs-core": "16.11.1",
    "fumadocs-docgen": "^3.1.0",
    "fumadocs-mdx": "15.1.0",
    "fumadocs-twoslash": "^3.3.0",
    "fumadocs-typescript": "^5.3.0",
    "fumadocs-ui": "16.11.1",
    "lucide-react": "^1.23.0",
    "mdast-util-from-markdown": "^2.0.2",
    "mdast-util-gfm": "^3.1.0",
    "mdast-util-to-hast": "^13.2.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "shiki": "^4.3.1",
    "twoslash": "^0.3.9"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@types/hast": "^3.0.4",
    "@types/mdx": "^2.0.14",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "nitro": "3.0.260610-beta",
    "serve": "^14.2.6",
