---
import DefaultHead from "@astrojs/starlight/components/Head.astro";
import { base } from "astro:config/client";
import { getImagePath } from "astro-takumi";

const { url, site } = Astro;

if (!site) {
  throw new Error("Astro `site` must be configured.");
}

const isNotFound =
  url.pathname === `${base}404` ||
  url.pathname === `${base}404/` ||
  url.pathname.endsWith("/not-found") ||
  url.pathname.endsWith("/not-found/");

const image = isNotFound
  ? // workaround for Takumi image to work on base path being set
    new URL(`${base.replace(/\/?$/, "/")}404.webp`, site.origin).href
  : getImagePath({ url, site, format: "webp" });
---

<DefaultHead />
<meta property="og:image" content={image} />
