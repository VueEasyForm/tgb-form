---
import DefaultHead from "@astrojs/starlight/components/Head.astro";
import { base } from "astro:config/client";
import { getImagePath } from "astro-takumi";

const { url, site } = Astro;

if (!site) {
  throw new Error("Astro `site` must be configured.");
}

const pathname = url.pathname.startsWith(base)
  ? url.pathname.slice(base.length) || "/"
  : url.pathname;
const image = getImagePath({
  url: new URL(pathname, site),
  site: new URL("/", site),
  format: "webp",
});
---

<DefaultHead />
<meta property="og:image" content={image} />
