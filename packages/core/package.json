{
  "name": "@tgb-form/core",
  "version": "0.0.2",
  "description": "An easy to use form library, with powerful schema-based form definition capabilities.",
  "homepage": "https://github.com/VueEasyForm/tgb-form#readme",
  "bugs": {
    "url": "https://github.com/VueEasyForm/tgb-form/issues"
  },
  "license": "MIT",
  "author": "The @tgb-form Authors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VueEasyForm/tgb-form.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.mts",
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsdown": "^0.22.4",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "@tanstack/form-core": "^1.33.0",
    "valibot": "^1.4.1"
  }
}
