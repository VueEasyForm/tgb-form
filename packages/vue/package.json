{
  "name": "@tgb-form/vue",
  "version": "0.0.2",
  "description": "An easy to use form library for Vue, built on top of @tgb-form/core.",
  "homepage": "https://github.com/VueEasyForm/tgb-form#readme",
  "bugs": {
    "url": "https://github.com/VueEasyForm/tgb-form/issues"
  },
  "license": "MIT",
  "author": "The @tgb-form Authors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VueEasyForm/tgb-form.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "play": "vite",
    "test": "vitest --run",
    "typecheck": "vue-tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "@tanstack/vue-form": "^1.33.2",
    "@tgb-form/core": "workspace:*",
    "@tsdown/css": "^0.22.9",
    "@types/node": "^26.1.1",
    "@vitejs/plugin-vue": "^6.0.8",
    "@vitest/browser-playwright": "^4.1.10",
    "playwright": "^1.61.1",
    "tsdown": "^0.22.9",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.1.10",
    "vitest-browser-vue": "^2.1.0",
    "vue": "^3.5.40",
    "vue-tsc": "^3.3.7"
  },
  "peerDependencies": {
    "@tanstack/vue-form": "^1.33.0",
    "vue": "^3.0.0"
  }
}
