{
  "name": "@easyform/react",
  "version": "0.0.1",
  "description": "An easy to use form library for React, built on top of @easyform/core.",
  "homepage": "https://github.com/VueEasyForm/easyform#readme",
  "bugs": {
    "url": "https://github.com/VueEasyForm/easyform/issues"
  },
  "license": "MIT",
  "author": "The @easyform Authors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VueEasyForm/easyform.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "play": "vite",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "@tsconfig/strictest": "^2.0.8",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/browser-playwright": "^4.1.9",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3",
    "vite": "^8.1.1",
    "vitest": "^4.1.9",
    "vitest-browser-react": "^2.2.0"
  },
  "peerDependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  }
}
