{
  "name": "@easyform/react",
  "version": "0.0.1",
  "description": "An easy to use form library for React, built on top of @easyform/core.",
  "homepage": "https://github.com/VueEasyForm/easyform#readme",
  "bugs": {
    "url": "https://github.com/VueEasyForm/easyform/issues"
  },
  "license": "MIT",
  "author": "The @easyform Authors",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/VueEasyForm/easyform.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "play": "vite",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "@easyform/core": "workspace:*",
    "@tanstack/react-form": "^1.33.0",
    "@tsconfig/strictest": "^2.0.8",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/browser-playwright": "^4.1.10",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsdown": "^0.22.4",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10",
    "vitest-browser-react": "^2.2.0"
  },
  "peerDependencies": {
    "@tanstack/react-form": "^1.33.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  }
}
